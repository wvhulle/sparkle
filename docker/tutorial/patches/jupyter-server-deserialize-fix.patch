diff --git a/jupyter_server/services/kernels/connection/base.py b/jupyter_server/services/kernels/connection/base.py
index 6af1044..3f604ca 100644
--- a/jupyter_server/services/kernels/connection/base.py
+++ b/jupyter_server/services/kernels/connection/base.py
@@ -63,8 +63,43 @@ def deserialize_binary_message(bmsg):
     Returns
     -------
     message dictionary
+
+    Raises
+    ------
+    ValueError
+        If the buffer header is inconsistent with its size — for
+        example because the frame is in the v1 wire format (which
+        has a different header layout) and was misrouted here.
+        Callers should treat this as a "drop the frame, keep the
+        socket alive" condition rather than letting it propagate
+        and tear the WebSocket down.
     """
+    if len(bmsg) < 4:
+        msg = "binary message shorter than the 4-byte nbufs header"
+        raise ValueError(msg)
     nbufs = struct.unpack("!i", bmsg[:4])[0]
+    # Sanity-bound `nbufs`.  A legitimate message has very few buffers
+    # (header + parent + metadata + content + a handful of binary
+    # buffers).  An accidentally-routed v1-protocol frame parsed
+    # here can give nbufs in the hundreds of millions, which then
+    # blows up `struct.unpack` with an obscure "buffer of N bytes"
+    # error and tears the WebSocket stream down.  Fail with a clear
+    # ValueError instead so callers can drop the frame.
+    max_nbufs = 1024
+    if nbufs < 0 or nbufs > max_nbufs:
+        msg = (
+            f"binary message header nbufs={nbufs} outside expected range "
+            f"[0, {max_nbufs}] — frame likely uses a different wire "
+            f"format (e.g. the v1 protocol) than this deserializer expects"
+        )
+        raise ValueError(msg)
+    needed = 4 * (nbufs + 1)
+    if len(bmsg) < needed:
+        msg = (
+            f"binary message truncated: nbufs={nbufs} requires "
+            f"{needed} header bytes, only {len(bmsg)} present"
+        )
+        raise ValueError(msg)
     offsets = list(struct.unpack("!" + "I" * nbufs, bmsg[4 : 4 * (nbufs + 1)]))
     offsets.append(None)
     bufs = []
